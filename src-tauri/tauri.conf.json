{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FocusForge",
  "version": "0.1.0",
  "identifier": "com.focusforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FocusForge",
        "width": 1160,
        "height": 760,
        "minWidth": 920,
        "minHeight": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
